# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NVIDIA AI Configuration
NVIDIA_API_KEY=your-nvidia-api-key

# Apify (Job Scraping — LinkedIn, Indeed, Naukri)
APIFY_API_TOKEN=your-apify-api-token

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Gmail API Configuration (for email sync)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Browserless (for Playwright automation)
BROWSERLESS_TOKEN=your-browserless-token

# Application URLs
NEXT_PUBLIC_APP_URL=https://hirex.ai
NEXT_PUBLIC_API_URL=https://api.hirex.ai

# Encryption (for storing portal credentials)
ENCRYPTION_KEY=your-32-char-secret-key-here

# Inngest (Background Jobs)
INNGEST_EVENT_KEY=your-inngest-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Email Service (Resend/SendGrid for transactional emails)
RESEND_API_KEY=re_xxx

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
