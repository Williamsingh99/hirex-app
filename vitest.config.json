{
  "test": {
    "globals": true,
    "environment": "node",
    "include": ["__tests__/**/*.test.ts"],
    "exclude": ["node_modules", "dist", ".next"],
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "json", "html"],
      "exclude": [
        "node_modules",
        ".next",
        "__tests__",
        "**/*.config.*",
        "**/types/**"
      ]
    }
  }
}
